
# ------------------------------------------------------------------------------
# anthropics/skills (source-available, NOT open source)
# License: https://github.com/anthropics/skills - see LICENSE.txt in each skill
# Skills go to .agents/skills/anthropics/{skill}/ (Shared)
# - Hardcoded skill list
# ------------------------------------------------------------------------------
{{- $anthropicsSkills := list
  "pdf"
  "docx"
  "pptx"
  "xlsx"
  "skill-creator"
  "mcp-builder"
  "canvas-design"
  "webapp-testing"
  "doc-coauthoring"
  "internal-comms"
  "brand-guidelines"
  "theme-factory"
  "web-artifacts-builder"
  "algorithmic-art"
  "slack-gif-creator"
}}

{{- range $skill := $anthropicsSkills }}
[".agents/skills/anthropics/{{ $skill }}"]
    type = "archive"
    url = "https://github.com/anthropics/skills/archive/{{ $.versions.claudeAnthropicsSkillsRev }}.tar.gz"
    checksum.sha256 = "{{ $.versions.claudeAnthropicsSkillsSha256 }}"
    exact = true
    stripComponents = 3
    include = ["skills-*/skills/{{ $skill }}/**"]
    refreshPeriod = "168h"

{{ end }}


# ------------------------------------------------------------------------------
# vercel-labs/agent-skills frontend set
# ------------------------------------------------------------------------------
{{- $vercelSkills := list
  "react-best-practices"
  "composition-patterns"
  "web-design-guidelines"
  "react-native-skills"
}}
{{- range $skill := $vercelSkills }}
[".agents/skills/ecosystem/vercel-labs/{{ $skill }}"]
    type = "archive"
    url = "https://github.com/vercel-labs/agent-skills/archive/{{ $.versions.vercelLabsAgentSkillsRev }}.tar.gz"
    exact = true
    stripComponents = 3
    include = ["agent-skills-*/skills/{{ $skill }}/**"]
    refreshPeriod = "168h"

{{- end }}


[".agents/skills/ui-ux-pro-max"]
    type = "archive"
    url = "https://github.com/nextlevelbuilder/ui-ux-pro-max-skill/archive/{{ $.versions.uiUxProMaxSkillRev }}.tar.gz"
    checksum.sha256 = "{{ $.versions.uiUxProMaxSkillSha256 }}"
    exact = false
    stripComponents = 4
    include = ["ui-ux-pro-max-skill-*/.claude/skills/ui-ux-pro-max/SKILL.md"]
    refreshPeriod = "168h"

[".agents/skills/ui-ux-pro-max/data"]
    type = "archive"
    url = "https://github.com/nextlevelbuilder/ui-ux-pro-max-skill/archive/{{ $.versions.uiUxProMaxSkillRev }}.tar.gz"
    checksum.sha256 = "{{ $.versions.uiUxProMaxSkillSha256 }}"
    exact = true
    stripComponents = 4
    include = ["ui-ux-pro-max-skill-*/src/ui-ux-pro-max/data/**"]
    refreshPeriod = "168h"

[".agents/skills/ui-ux-pro-max/scripts"]
    type = "archive"
    url = "https://github.com/nextlevelbuilder/ui-ux-pro-max-skill/archive/{{ $.versions.uiUxProMaxSkillRev }}.tar.gz"
    checksum.sha256 = "{{ $.versions.uiUxProMaxSkillSha256 }}"
    exact = true
    stripComponents = 4
    include = ["ui-ux-pro-max-skill-*/src/ui-ux-pro-max/scripts/**"]
    refreshPeriod = "168h"